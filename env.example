# Copy to `.env` and adjust if needed (`cp env.example .env`). All values have
# sensible defaults in config/settings.py, so the suite runs without a .env too.

# --- UI target: SauceDemo ---
UI_BASE_URL=https://www.saucedemo.com
UI_USERNAME=standard_user
UI_PASSWORD=secret_sauce

# --- API target: restful-booker ---
API_BASE_URL=https://restful-booker.herokuapp.com
API_USERNAME=admin
API_PASSWORD=password123

# --- Runtime ---
# Default action timeout for UI/API operations, milliseconds.
DEFAULT_TIMEOUT_MS=15000
